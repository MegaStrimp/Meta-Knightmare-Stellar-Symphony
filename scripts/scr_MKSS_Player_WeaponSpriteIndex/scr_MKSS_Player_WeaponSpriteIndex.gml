function scr_MKSS_Player_WeaponSpriteIndex()
{
	var weaponSpriteIndex = undefined;
	
	switch (sprite_index)
	{
		case spriteSet.sprIdle:
		weaponSpriteIndex = weaponSpriteSet.sprIdle;
		break;
		
		case spriteSet.sprWalk:
		weaponSpriteIndex = weaponSpriteSet.sprWalk;
		break;
		
		case spriteSet.sprRun:
		weaponSpriteIndex = weaponSpriteSet.sprRun;
		break;
		
		case spriteSet.sprRunTurn:
		weaponSpriteIndex = weaponSpriteSet.sprRunTurn;
		break;
		
		case spriteSet.sprJumpReady:
		weaponSpriteIndex = weaponSpriteSet.sprJumpReady;
		break;
		
		case spriteSet.sprJump:
		weaponSpriteIndex = weaponSpriteSet.sprJump;
		break;
		
		case spriteSet.sprRoll:
		weaponSpriteIndex = weaponSpriteSet.sprRoll;
		break;
		
		case spriteSet.sprFall:
		weaponSpriteIndex = weaponSpriteSet.sprFall;
		break;
		
		case spriteSet.sprFallHop:
		weaponSpriteIndex = weaponSpriteSet.sprFallHop;
		break;
		
		case spriteSet.sprDuck:
		weaponSpriteIndex = weaponSpriteSet.sprDuck;
		break;
		
		case spriteSet.sprUpDuck:
		weaponSpriteIndex = weaponSpriteSet.sprUpDuck;
		break;
		
		case spriteSet.sprSquish:
		weaponSpriteIndex = weaponSpriteSet.sprSquish;
		break;
		
		case spriteSet.sprSlide:
		weaponSpriteIndex = weaponSpriteSet.sprSlide;
		break;
		
		case spriteSet.sprFloat:
		weaponSpriteIndex = weaponSpriteSet.sprFloat;
		break;
		
		case spriteSet.sprFlap:
		weaponSpriteIndex = weaponSpriteSet.sprFlap;
		break;
		
		case spriteSet.sprClimbUp:
		weaponSpriteIndex = weaponSpriteSet.sprClimbUp;
		break;
		
		case spriteSet.sprClimbDown:
		weaponSpriteIndex = weaponSpriteSet.sprClimbDown;
		break;
		
		case spriteSet.sprFloatSpit:
		weaponSpriteIndex = weaponSpriteSet.sprFloatSpit;
		break;
		
		case spriteSet.sprDoorEnter:
		weaponSpriteIndex = weaponSpriteSet.sprDoorEnter;
		break;
		
		case spriteSet.sprHurtNormal:
		weaponSpriteIndex = weaponSpriteSet.sprHurtNormal;
		break;
		
		case spriteSet.sprHurtShocked:
		weaponSpriteIndex = weaponSpriteSet.sprHurtShocked;
		break;
		
		case spriteSet.sprHurtBurned:
		weaponSpriteIndex = weaponSpriteSet.sprHurtBurned;
		break;
		
		case spriteSet.sprHurtFrozen:
		weaponSpriteIndex = weaponSpriteSet.sprHurtFrozen;
		break;
		
		case spriteSet.sprParry:
		weaponSpriteIndex = weaponSpriteSet.sprParry;
		break;
		
		case spriteSet.sprAttackGalaxiaSlash1:
		weaponSpriteIndex = weaponSpriteSet.sprAttackGalaxiaSlash1;
		break;
		
		case spriteSet.sprAttackGalaxiaSlash2:
		weaponSpriteIndex = weaponSpriteSet.sprAttackGalaxiaSlash2;
		break;
		
		case spriteSet.sprAttackGalaxiaStab:
		weaponSpriteIndex = weaponSpriteSet.sprAttackGalaxiaStab;
		break;
		
		case spriteSet.sprAttackGalaxiaUpAttack:
		weaponSpriteIndex = weaponSpriteSet.sprAttackGalaxiaUpAttack;
		break;
		
		case spriteSet.sprAttackGalaxiaDownThrust:
		weaponSpriteIndex = weaponSpriteSet.sprAttackGalaxiaDownThrust;
		break;
		
		case spriteSet.sprAttackGalaxiaDownThrustEnd:
		weaponSpriteIndex = weaponSpriteSet.sprAttackGalaxiaDownThrustEnd;
		break;
		
		case spriteSet.sprAttackGalaxiaMachTornado:
		weaponSpriteIndex = weaponSpriteSet.sprAttackGalaxiaMachTornado;
		break;
		
		case spriteSet.sprAttackBuzzcutSlash1:
		weaponSpriteIndex = weaponSpriteSet.sprAttackBuzzcutSlash1;
		break;
		
		case spriteSet.sprAttackBuzzcutSlash2:
		weaponSpriteIndex = weaponSpriteSet.sprAttackBuzzcutSlash2;
		break;
	}
	
	return weaponSpriteIndex;
}